{
    "builds": [
        {
            "src": "backend/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "frontend/$1"
        }
    ]
}